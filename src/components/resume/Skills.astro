---
// No props needed
---

<section class="resume-section scroll-reveal-animate">
  <h2>Skills</h2>
  <div class="skills-grid">
    <div class="skill-category">
      <h3>Programming</h3>
      <ul>
        <li>Python</li>
        <li>R</li>
        <li>SQL</li>
        <li>Java</li>
        <li>JavaScript & TypeScript</li>
        <li>React</li>
        <li>Git & GitHub</li>
        <li>CSS & Sass</li>
        <li>HTML</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Analytical</h3>
      <ul>
        <li>Machine Learning</li>
        <li>Environmental Modeling</li>
        <li>Data Visualization</li>
        <li>Causal Inference</li>
        <li>Geospatial Analysis</li>
        <li>Remote Sensing</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Software & Tools</h3>
      <ul>
        <li>QGIS</li>
        <li>ArcGIS</li>
        <li>WordPress</li>
        <li>Canva</li>
        <li>Affinity Designer</li>
        <li>Microsoft Office</li>
        <li>Google Suite</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Languages</h3>
      <ul>
        <li>English (Native)</li>
        <li>French (Intermediate)</li>
        <li>Spanish (Basic)</li>
        <li>Korean (Basic)</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Certifications</h3>
      <ul>
        <li>EMT-B (In Progress)</li>
        <li>Wilderness First Responder</li>
        <li>Basic Life Support CPR</li>
        <li>Epinephrine Injection</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .resume-section {
    margin-bottom: 4rem;
  }
  h2 {
    font-size: clamp(1.8rem, 1.5rem + 1.5vw, 2.8rem);
    margin-bottom: 2rem;
    font-weight: 600;
    border-bottom: 1px solid var(--text-muted);
    padding-bottom: 0.5rem;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(120px, 1fr)
    ); /* Responsive grid */
    gap: 2rem; /* Space between columns and rows */
  }
  .skill-category h3 {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-color);
  }
  .skill-category ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.7;
  }
  .skill-category li {
    margin-bottom: 0.4rem;
    color: var(--text-muted); /* Slightly muted color for skill items */
  }

  @media (min-width: 900px) and (max-width: 1200px) {
    .scroll-reveal-animate {
      opacity: 1 !important;
      filter: none !important;
      transform: none !important;
      transition: none !important;
      will-change: auto;
    }
  }

  .skills-entry p {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .award-entry .header {
      flex-direction: column;
      align-items: flex-start;
    }
    .award-entry .date {
      margin-top: 0.3rem;
      padding-left: 0;
    }
  }
</style>
