---
// No props needed for now
---

<section class="resume-section scroll-reveal-animate">
  <h2>Education</h2>
  <div class="education-entry">
    <div class="header">
      <span class="institution"
        ><strong>University of California, Santa Barbara</strong><br /> Master's of
        Environmental Data Science &emsp; <wbr /> GPA: <strong>4.0</strong><br
        />
      </span>
      <span class="date">June 2025</span>
    </div>
    <p>
      <strong><em>Highlighted Coursework:</em></strong> Geospatial Analysis and Remote
      Sensing, Machine Learning, Databases and Data Management, Environmental Modeling,
      Ethics and Bias in Environmental Data Science
    </p>
  </div>
  <div class="education-entry">
    <div class="header">
      <span class="institution"
        ><strong>University of California, Berkeley</strong><br /> B.S. in Environmental
        Science, <em>Honors</em> &emsp; <wbr /> GPA: <strong>3.8</strong><br />
      </span>
      <span class="date">May 2021</span>
    </div>
    <p>
      <strong><em>Highlighted Coursework:</em></strong> Quantitative Aspects of Global
      Environmental Problems, Environmental Economics, Culture and Resource Management,
      Climate and Resource Policy, Energy and Society
    </p>
  </div>
</section>

<style>
  .resume-section {
    margin-bottom: 4rem;
  }
  h2 {
    font-size: clamp(1.8rem, 1.5rem + 1.5vw, 2.8rem);
    margin-bottom: 2rem;
    font-weight: 600;
    border-bottom: 1px solid var(--text-muted);
    padding-bottom: 0.5rem;
  }
  .education-entry .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap; /* Allow wrapping on smaller screens */
    margin-bottom: 0.8rem;
    font-size: 1.3rem;
  }
  .education-entry .institution {
    margin-right: 1rem; /* Space between institution and date */
  }
  .education-entry .date {
    font-family: var(--font-family-sans);
    color: var(--text-muted);
    font-size: 1rem;
    white-space: nowrap; /* Prevent date from wrapping */
  }
  .education-entry .details {
    list-style: none;
    padding-left: 0;
    margin-left: 1rem; /* Indent details slightly */
    font-size: 1.2rem;
    line-height: 1.6;
  }
  .education-entry .details li {
    margin-bottom: 0.3rem;
  }

  .education-entry p {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .education-entry .header {
      flex-direction: column; /* Stack header items vertically */
      align-items: flex-start;
    }
    .education-entry .date {
      margin-top: 0.3rem;
    }
    .education-entry .details {
      margin-left: 0; /* Remove indent on mobile */
    }
  }
</style>
