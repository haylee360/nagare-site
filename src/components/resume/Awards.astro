  .award-entry {
    margin-bottom: 1.5rem;
  }
  .award-entry:last-child {
    margin-bottom: 0;
  }
  .award-entry .header {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    font-size: 1.2rem;
    line-height: 1.5;
    align-items: baseline;
  }
  .award-entry .institution {
    margin-right: 1rem;
  }
  .award-entry .date {
    font-family: var(--font-family-sans);
    color: var(--text-muted);
    font-size: 1rem;
    white-space: nowrap;
    padding-left: 1rem;
  }
  .award-entry a {
    color: var(--text-muted);
    word-break: break-all;
  }
  .award-entry p {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .award-entry .header {
      flex-direction: column;
      align-items: flex-start;
    }
    .award-entry .date {
      margin-top: 0.3rem;
      padding-left: 0;
    }
  }
