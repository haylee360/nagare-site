---
// Content for the "Meet me!" section
import Button from "../../common/Button.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import headshotImage from "../../../assets/images/echo_headshot_square.jpeg";

const resumeUrl = "/resume";
---

<h2 slot="title" class="about-title scroll-target-title">About me</h2>

<div class="about-content scroll-target-content">
  <div class="about-grid">
    <!-- Left column: text + button -->
    <div class="about-text">
      <p>
        My name is Haylee Oyler (she/they) and I am an interdisciplinary
        environmental data scientist. In other words, I want to understand
        environmental problems using approaches, frameworks, and methods across
        different fields of study. I've always been interested in understanding
        the intersection of people and nature. For me, the most conspicuous path
        into this nexus was a degree in environmental science from UC Berkeley.
        I gained experience studying human-environment interactions and it also
        introduced me to working with data.
      </p>
      <div class="button-group">
        <Button
          class="button"
          href={resumeUrl}
          text="View My CV"
          wrapperClass="meet-me-cta-button"
        />
      </div>
    </div>

    <!-- Right column: headshot + social icons -->
    <div class="about-image-col">
      <div class="headshot-wrapper">
        <Image
          src={headshotImage}
          alt="Haylee Oyler"
          class="headshot"
          loading="lazy"
        />
      </div>

      <div class="social-links">
        <!-- Email -->
        <a
          href="mailto:hayleeoyler@proton.me"
          aria-label="Email"
          class="social-icon"
        >
          <Icon name="ri:mail-line" size={24} aria-hidden="true" />
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/haylee360"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-icon"
        >
          <Icon name="ri:github-line" size={22} aria-hidden="true" />
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/haylee-oyler/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-icon"
        >
          <Icon name="ri:linkedin-box-line" size={22} aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Added from chat to put headshot on second slide */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 1:1 spacing */
    gap: 3rem;
    align-items: start;
    justify-content: center;
  }

  /* Stack image below text on small screens */
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-image-col {
      order: 2;
    }

    .about-text {
      order: 1;
    }
  }

  /* Left column */
  .about-text p {
    line-height: 1.8;
    margin-top: 0;
  }

  .button-group {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  /* Right column */
  .about-image-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .headshot-wrapper {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px; /* subtle rounding — remove for a hard edge */
  }

  /* Constrain image size on smaller screens */
  @media (max-width: 760px) {
    .headshot-wrapper {
      max-width: 280px;
    }
  }

  @media (max-width: 600px) {
    .headshot-wrapper {
      max-width: 240px;
    }
  }

  .headshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top; /* adjust if your headshot crops oddly */
    display: block;
  }

  /* Social icons row */
  .social-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-icon {
    color: var(--text-muted);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .social-icon:hover {
    color: var(--text-color);
    text-decoration: none;
  }

  .social-icon svg {
    width: 22px;
    height: 22px;
  }
</style>
