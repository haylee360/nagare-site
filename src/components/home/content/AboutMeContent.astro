---
// Content for the "Meet me!" section
import Button from "../../common/Button.astro";

const resumeUrl = "/resume";
---

<h2 slot="title" class="about-title scroll-target-title">About me</h2>

<div class="about-content scroll-target-content">
  <div class="about-grid">
    <!-- Left column: text + button -->
    <div class="about-text">
      <p>
        My name is Haylee Oyler (she/they) and I am an interdisciplinary
        environmental data scientist. In other words, I want to understand
        environmental problems using approaches, frameworks, and methods across
        different fields of study. I've always been interested in understanding
        the intersection of people and nature. For me, the most conspicuous path
        into this nexus was a degree in environmental science from UC Berkeley.
        I gained experience studying human-environment interactions and it also
        introduced me to working with data.
      </p>
      <div class="button-group">
        <Button
          class="button"
          href={resumeUrl}
          text="View My CV"
          wrapperClass="meet-me-cta-button"
        />
      </div>
    </div>

    <!-- Right column: headshot + social icons -->
    <div class="about-image-col">
      <div class="headshot-wrapper">
        <img
          src="/images/echo_headshot_square.jpeg"
          alt="Haylee Oyler"
          class="headshot"
        />
      </div>

      <div class="social-links">
        <!-- Email -->
        <a
          href="mailto:hayleeoyler@proton.me"
          aria-label="Email"
          class="social-icon"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M2 6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6z"
              stroke="currentColor"
              stroke-width="1.5"></path>
            <path
              d="M2 6l10 7 10-7"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/haylee360"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-icon"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/haylee-oyler/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-icon"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 23.2 24 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Added from chat to put headshot on second slide */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 1:1 spacing */
    gap: 3rem;
    align-items: start;
    justify-content: center;
  }

  /* Stack image below text on small screens */
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-image-col {
      order: 2;
    }

    .about-text {
      order: 1;
    }
  }

  /* Left column */
  .about-text p {
    line-height: 1.8;
    margin-top: 0;
  }

  .button-group {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  /* Right column */
  .about-image-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .headshot-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px; /* subtle rounding — remove for a hard edge */
  }

  .headshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top; /* adjust if your headshot crops oddly */
    display: block;
  }

  /* Social icons row */
  .social-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-icon {
    color: var(--text-muted);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .social-icon:hover {
    color: var(--text-color);
    text-decoration: none;
  }

  .social-icon svg {
    width: 22px;
    height: 22px;
  }
</style>
