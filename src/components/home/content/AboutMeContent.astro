---
// Content for the "Meet me!" section
import Button from "../../common/Button.astro";

const resumeUrl = "/resume";
// const contactUrl = "/contact";
---

<h2 slot="title" class="about-title scroll-target-title">About me</h2>

<div class="about-content scroll-target-content">
  <p>
    My name is Haylee Oyler (she/they) and I am an interdisciplinary
    environmental data scientist. In other words, I want to understand
    environmental problems using approaches, frameworks, and methods across
    different fields of study. I’ve always been interested in understanding the
    intersection of people and nature. For me, the most conspicuous path into
    this nexus was a degree in environmental science from UC Berkeley. I gained
    experience studying human-environment interactions and it also introduced me
    to working with data.
  </p>

  <div class="button-group">
    <Button
      class="button"
      href={resumeUrl}
      text="View My CV"
      wrapperClass="meet-me-cta-button"
    />
  </div>
</div>

<style>
  .button-group {
    display: flex;
    gap: 1rem; /* Adjust spacing as needed */
    margin-top: 2rem;
  }
</style>
