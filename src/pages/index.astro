---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
import SectionWrapper from "../components/home/SectionWrapper.astro";
import AboutMeContent from "../components/home/content/AboutMeContent.astro";
import FeaturedWorksContent from "../components/home/content/FeaturedWorksContent.astro";
import HighlightsUpdatesContent from "../components/home/content/HighlightsUpdatesContent.astro";
import ConnectContent from "../components/home/content/ConnectContent.astro";
---

<Layout title="Homepage" snapScroll={true}>
  <main class="homepage-content">
    <Hero />

    <SectionWrapper>
      <AboutMeContent />
    </SectionWrapper>

    <SectionWrapper>
      <FeaturedWorksContent />
    </SectionWrapper>

    <SectionWrapper>
      <HighlightsUpdatesContent />
    </SectionWrapper>

    <SectionWrapper>
      <ConnectContent />
    </SectionWrapper>
  </main>
</Layout>

<style>
  .homepage-content {
    display: flex;
    flex-direction: column;
  }

  /* snap targets */
  .homepage-content > :global(*) {
    scroll-snap-align: start;
    scroll-snap-stop: always; /* forces stop at every slide, no skipping */
  }

  main {
    position: relative;
    width: 100%;
  }
</style>
